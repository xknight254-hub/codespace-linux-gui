{
  "name": "Linux GUI Desktop + SSH",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "GUI Desktop (noVNC)",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "bash /workspaces/codespace-linux-gui/setup.sh 2>&1 | tee /tmp/codespace-setup.log"
}
