{
  "name": "Linux GUI + SSH Workspace",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [7080, 2222],
  "portsAttributes": {
    "7080": {
      "label": "GUI Desktop (noVNC)",
      "onAutoForward": "openPreview"
    },
    "2222": {
      "label": "SSH into GUI container",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash /workspaces/codespace-linux-gui/setup.sh",
  "postStartCommand": "cd /workspaces/codespace-linux-gui && docker-compose up -d 2>/dev/null || true"
}
