{
  "name": "Linux GUI + SSH",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "debian-desktop",
  "workspaceFolder": "/config",
  "forwardPorts": [6080, 2222],
  "portsAttributes": {
    "6080": {
      "label": "GUI Desktop (noVNC)",
      "onAutoForward": "openPreview"
    },
    "2222": {
      "label": "SSH Access",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "echo 'Codespace ready! GUI on port 6080, SSH on port 2222'"
}
